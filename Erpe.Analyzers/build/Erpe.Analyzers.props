<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Nullable>enable</Nullable>
    <AnalysisLevel>latest-all</AnalysisLevel>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <AdditionalFiles Include="$(MSBuildThisFileDirectory)../tools/stylecop.json" Link="stylecop.json"/>
    <GlobalAnalyzerConfigFiles Include="$(MSBuildThisFileDirectory)../tools/Erpe.Analyzers.globalconfig" Link="Erpe.Analyzers.globalconfig"/>
  </ItemGroup>
</Project>